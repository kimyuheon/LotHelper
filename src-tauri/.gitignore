# Generated by Cargo
# will have compiled files and executables
/target/

# Generated by Tauri
# will have schema files for capabilities auto-completion
/gen/schemas

# llama-server binaries and shared libraries (large, per-OS) — keep only the READMEs
/llama/**/*
!/llama/**/
!/llama/**/README.md

# Model weights (large, OS-independent) — keep only the README
/models/*
!/models/README.md
